---
import { getCollection } from "astro:content";
import SiteNav from "../../components/SiteNav.astro";
import SiteFooter from "../../components/SiteFooter.astro";
const base = import.meta.env.BASE_URL;

export async function getStaticPaths() {
  const posts = await getCollection("blog", (p) => !p.data.draft);
  const cats = [...new Set(posts.map((p) => p.data.category))];
  return cats.map((c) => ({
    params: { category: c.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-|-$/g, "") },
    props: { category: c, posts: posts.filter((p) => p.data.category === c) },
  }));
}
const { category, posts } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{category} — The Luya Blog</title>
    <meta name="description" content={`Luya blog articles in ${category}.`} />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800&family=Lora:wght@600;700&display=swap" rel="stylesheet" />
  </head>
  <body style="margin:0;font-family:'DM Sans',system-ui,sans-serif;color:#1a2e22;">
    <SiteNav />
    <main style="max-width:880px;margin:0 auto;padding:32px 20px;">
      <h1 style="font-family:'Lora',serif;">{category}</h1>
      <ul style="line-height:2;">
        {posts.map((p) => <li><a style="color:#2F9160;" href={base + "/" + p.slug + "/"}>{p.data.title}</a></li>)}
      </ul>
    </main>
    <SiteFooter />
  </body>
</html>
