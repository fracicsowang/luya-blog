---
import { getCollection } from "astro:content";
import SiteNav from "../components/SiteNav.astro";
import SiteFooter from "../components/SiteFooter.astro";
import Newsletter from "../components/Newsletter.astro";
const base = import.meta.env.BASE_URL;
const posts = (await getCollection("blog", (p) => !p.data.draft))
  .sort((a, b) => +new Date(b.data.date ?? 0) - +new Date(a.data.date ?? 0));
const site = "https://luyaxyz.com";
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>The Luya Blog — Microgreens, Nutrition & Home Growing</title>
    <meta name="description" content="Science-backed guides on microgreens nutrition, health, recipes, and growing fresh greens at home with Luya." />
    <link rel="canonical" href={site + "/blog/"} />
    <link rel="alternate" type="application/rss+xml" title="Luya Blog" href={site + "/blog/feed.xml"} />
    <meta property="og:title" content="The Luya Blog" />
    <meta property="og:description" content="Microgreens nutrition, health, recipes, and home growing — by Luya." />
    <meta property="og:image" content={site + "/blog/img/og-default.png"} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800&family=Lora:wght@500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <SiteNav />
    <main class="wrap">
      <header class="head">
        <h1>The Luya Blog</h1>
        <p>Microgreens nutrition, health, recipes, and growing fresh greens at home.</p>
      </header>
      <div class="grid">
        {posts.map((p) => (
          <a class="card" href={base + "/" + p.slug + "/"}>
            {p.data.image && <img src={p.data.image} alt={p.data.image_alt || p.data.title} loading="lazy" />}
            <div class="body">
              <span class="cat">{p.data.category}</span>
              <h2>{p.data.title}</h2>
              <p>{p.data.description}</p>
            </div>
          </a>
        ))}
      </div>
      <Newsletter />
    </main>
    <SiteFooter />
    <style>
      * { box-sizing:border-box; }
      body { margin:0; font-family:"DM Sans",system-ui,sans-serif; color:#1a2e22; background:#fff; }
      .wrap { max-width:980px; margin:0 auto; padding:32px 20px; }
      .head h1 { font-family:"Lora",serif; font-size:42px; margin:0 0 8px; }
      .head p { color:#5b6b62; font-size:18px; margin:0 0 28px; }
      .grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(300px,1fr)); gap:22px; }
      .card { border:1px solid #e6ece8; border-radius:14px; overflow:hidden; text-decoration:none; color:inherit; background:#fff; transition:box-shadow .2s,transform .2s; display:flex; flex-direction:column; }
      .card:hover { box-shadow:0 10px 30px rgba(0,0,0,.08); transform:translateY(-2px); }
      .card img { width:100%; aspect-ratio:3/2; object-fit:cover; }
      .card .body { padding:16px 18px; }
      .card .cat { color:#2F9160; font-size:12px; font-weight:700; text-transform:uppercase; letter-spacing:.04em; }
      .card h2 { font-size:19px; margin:6px 0 8px; line-height:1.3; }
      .card p { color:#5b6b62; font-size:14px; margin:0; display:-webkit-box; -webkit-line-clamp:3; -webkit-box-orient:vertical; overflow:hidden; }
    </style>
  </body>
</html>
