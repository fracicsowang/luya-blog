---
import SiteNav from "../components/SiteNav.astro";
import SiteFooter from "../components/SiteFooter.astro";
const { frontmatter, url } = Astro.props;
const site = Astro.site?.toString().replace(/\/$/, "") || "https://luyaxyz.com";
const canonical = new URL(url ?? Astro.url.pathname, Astro.site).toString();
const fm = frontmatter;
const pub = fm.date ? new Date(fm.date) : new Date();
const ogImage = fm.image
  ? (fm.image.startsWith("http") ? fm.image : site + fm.image)
  : site + "/blog/img/og-default.png";
const authorIsExpert = fm.author && fm.author.toLowerCase().includes("shaiek");
const jsonld = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: fm.title,
  description: fm.description,
  image: ogImage,
  datePublished: pub.toISOString(),
  dateModified: pub.toISOString(),
  author: { "@type": "Person", name: fm.author || "Luya Editorial",
    ...(fm.author_role ? { jobTitle: fm.author_role } : {}) },
  publisher: { "@type": "Organization", name: "Luya",
    logo: { "@type": "ImageObject", url: site + "/blog/img/luya-logo.png" } },
  mainEntityOfPage: { "@type": "WebPage", "@id": canonical },
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fm.title} | Luya</title>
    <meta name="description" content={fm.description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="article" />
    <meta property="og:title" content={fm.title} />
    <meta property="og:description" content={fm.description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fm.title} />
    <meta name="twitter:description" content={fm.description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="alternate" type="application/rss+xml" title="Luya Blog" href={site + "/blog/feed.xml"} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800&family=Lora:ital,wght@0,500;0,600;0,700;1,400&display=swap" rel="stylesheet" />
    <set:html innerHTML={`<script type="application/ld+json">${JSON.stringify(jsonld)}</script>`} />
  </head>
  <body>
    <SiteNav />
    <article class="post">
      <p class="crumbs"><a href={import.meta.env.BASE_URL + "/"}>Blog</a> / {fm.category}</p>
      <h1>{fm.title}</h1>
      <p class="meta">
        By <strong>{fm.author}</strong>{fm.author_role ? `, ${fm.author_role}` : ""}
        {fm.read_time ? ` · ${fm.read_time}` : ""}
      </p>
      {fm.image && <img class="hero" src={fm.image} alt={fm.image_alt || fm.title} />}
      <div class="content"><slot /></div>
    </article>
    <SiteFooter />
    <style is:global>
      :root { --green:#2F9160; --ink:#1a2e22; --muted:#5b6b62; }
      * { box-sizing: border-box; }
      body { margin:0; font-family:"DM Sans",system-ui,sans-serif; color:var(--ink); background:#fff; line-height:1.7; }
      .post { max-width: 760px; margin: 0 auto; padding: 32px 20px 8px; }
      .crumbs { color:var(--muted); font-size:13px; margin:0 0 12px; }
      .crumbs a { color:var(--green); text-decoration:none; }
      .post h1 { font-family:"Lora",serif; font-size:40px; line-height:1.15; margin:0 0 12px; letter-spacing:-0.01em; }
      .meta { color:var(--muted); font-size:14px; margin:0 0 24px; }
      .hero { width:100%; height:auto; border-radius:14px; margin:0 0 28px; }
      .content { font-size:18px; }
      .content h2 { font-family:"Lora",serif; font-size:27px; margin:38px 0 12px; }
      .content h3 { font-size:20px; margin:28px 0 8px; }
      .content p { margin:0 0 18px; }
      .content a { color:var(--green); }
      .content img { width:100%; height:auto; border-radius:12px; margin:24px 0; }
      .content ul, .content ol { margin:0 0 18px; padding-left:22px; }
      .content li { margin:6px 0; }
      .content blockquote { border-left:3px solid var(--green); margin:20px 0; padding:4px 0 4px 18px; color:var(--muted); font-style:italic; }
      .content table { width:100%; border-collapse:collapse; margin:24px 0; font-size:15px; }
      .content th, .content td { border:1px solid #e2eae5; padding:10px 12px; text-align:left; }
      .content th { background:#f1f9f4; }
      .content em { color:var(--muted); }
      .content hr { border:0; border-top:1px solid #e6ece8; margin:32px 0; }
      .content code { background:#f1f5f3; padding:2px 6px; border-radius:4px; font-size:0.9em; }
    </style>
  </body>
</html>
